{
  "name": "frankenmermaid",
  "pages_build_output_dir": "./dist/cloudflare-pages/latest",
  "compatibility_date": "2026-04-06",
  "vars": {
    "FM_CANONICAL_HOST": "frankenmermaid.com",
    "FM_STATIC_ROUTE": "/web",
    "FM_REACT_ROUTE": "/web_react",
    "FM_DEPLOY_ENV": "local"
  },
  "env": {
    "preview": {
      "vars": {
        "FM_DEPLOY_ENV": "preview"
      }
    },
    "production": {
      "vars": {
        "FM_DEPLOY_ENV": "production"
      }
    }
  }
}
