# bv (beads viewer) local config and caches
.bv/

# macOS AppleDouble / resource fork files
._*

# Rust build artifacts
target/

# Web/WASM artifacts
pkg/
*.wasm
node_modules/

# Local scratch SQLite DBs (never tracked)
storage.sqlite3
storage.sqlite3-*
*.sqlite3.bak

# Common local artifacts (avoid accidental commits)
a.out
.plan.md
screenshots_for_diagnostics/
rustc-ice-*.txt
reports/
.agent-mail.yaml

# Parser test output garbage (files created by malformed diagram parsing)
B*nend*

# Beads recovery artifacts
.beads/*.orphan_*
.beads/*.corrupt_*
.beads/*.pre_recovery_*
.beads/*.recover*.sql

# Beads history snapshots (JSONL export is tracked, history is local)
.beads/.br_history/

# Beads ephemeral DB artifacts (rebuild, recovery, test, bad snapshots)
.beads/beads.db.bad_*
.beads/beads.db.rebuild_*
.beads/beads.db.fresh_*
.beads/beads.db.cachetest*
.beads/beads.db.cyclefix*
.beads/beads.db.exporttest*
.beads/beads.db.*.dumpfix
.beads/beads.db.*.reindexed
.beads/beads.db.*.repair*
.beads/recovery_*/

# Ephemeral agent session files
SESSION_TODO.md
SESSION_REPORT.md
SESSION_*.md
verify_*.sh
newfile.txt
repro_*.rs

# Test output binaries/files (parser test artifacts at repo root)
/test_*
